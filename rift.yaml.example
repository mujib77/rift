source:
  type: postgres
  url: postgres://user:password@localhost:5432/mydb
  slot: rift_slot
  publication: rift_pub

destinations:
  - name: webhook
    type: webhook
    url: https://myapp.com/webhook/changes
    headers:

  - name: analytics-db
    type: postgres
    url: postgres://user:password@analytics:5432/analytics

queue:
  enabled: true
  path: ./rift-queue
  max_size_mb: 1000

filter:
  script: ./filter.js